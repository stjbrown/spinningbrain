OPENROUTER_API_KEY=

# Agent model (Mastra model-router string). Defaults to openrouter/deepseek/deepseek-v4-flash.
SB_AGENT_MODEL=openrouter/deepseek/deepseek-v4-flash

# --- Workspace storage (Cloudflare R2, S3-compatible) ---
# The bucket root IS the agent's workspace (knowledge/, AGENTS.md, skills/).
SB_WORKSPACE_BUCKET=
SB_WORKSPACE_REGION=auto

# Set R2_ACCOUNT_ID (endpoint is derived) or R2_ENDPOINT directly.
R2_ACCOUNT_ID=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Durable local Mastra conversation and observational memory storage.
SB_MEMORY_PATH=.mastra/spinningbrain.db
